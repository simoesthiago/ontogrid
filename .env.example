APP_ENV=development
JWT_SECRET=change-me
ARTIFACTS_DIR=./src/backend/data/artifacts
SEED_DEMO_CATALOG=false
SCHEDULER_ENABLED=false
SCHEDULER_POLL_INTERVAL_SECONDS=300
SCHEDULER_FORCE_RUN_ON_STARTUP=false

# Runtime oficial de desenvolvimento: docker compose com TimescaleDB, Neo4j e Redis.
# SQLite fica reservado para testes locais rapidos.
POSTGRES_USER=ontogrid
POSTGRES_PASSWORD=ontogrid
POSTGRES_DB=ontogrid
POSTGRES_HOST=timescaledb
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://ontogrid:ontogrid@timescaledb:5432/ontogrid

NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=ontogrid_graph

REDIS_URL=redis://redis:6379/0
LLM_API_BASE_URL=
LLM_API_KEY=
LLM_MODEL=
COPILOT_CACHE_TTL_SECONDS=3600
ONS_CKAN_BASE_URL=https://dados.ons.org.br
ONS_CARGA_PACKAGE_ID=curva-de-carga-horaria
ONS_CARGA_RESOURCE_ID=
ONS_CARGA_URL=
ANEEL_CKAN_BASE_URL=https://dadosabertos.aneel.gov.br
ANEEL_TARIFAS_PACKAGE_ID=tarifas-distribuidoras-energia-eletrica
ANEEL_TARIFAS_RESOURCE_ID=
ANEEL_TARIFAS_URL=
CCEE_CKAN_BASE_URL=https://dadosabertos.ccee.org.br
CCEE_PLD_PACKAGE_ID=PLD_HORARIO
CCEE_PLD_RESOURCE_ID=
CCEE_PLD_URL=

API_BASE_URL=http://api:8000/api/v1
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000/api/v1
